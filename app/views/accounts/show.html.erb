<style>
  .page-header { margin-bottom: 32px; }
  .page-header h4 {
    font-size: 1.4rem; font-weight: 800; color: #0f172a;
    letter-spacing: -0.4px; margin-bottom: 4px;
  }
  .page-header p { color: #64748b; font-size: 0.9rem; margin: 0; }

  .account-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    max-width: 520px;
  }
  .account-card-header {
    padding: 16px 24px;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
  }
  .account-card-header span {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: #059669;
  }
  .account-card-body { padding: 24px; }

  .info-row {
    display: flex;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid #f1f5f9;
  }
  .info-label {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: #94a3b8;
    width: 140px; flex-shrink: 0;
  }
  .info-value { font-size: 0.9rem; font-weight: 600; color: #0f172a; }
  .role-pill {
    display: inline-block;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em;
    text-transform: uppercase; padding: 2px 10px; border-radius: 999px;
  }
  .role-admin { background: #fef9c3; color: #92400e; }
  .role-user  { background: #f1f5f9; color: #475569; }

  .field-group { margin-bottom: 18px; }
  .field-group label {
    display: block;
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: #64748b; margin-bottom: 6px;
  }
  .field-group input {
    width: 100%;
    border: 1.5px solid #e2e8f0;
    border-radius: 8px;
    padding: 9px 12px;
    font-size: 0.9rem;
    color: #0f172a;
    background: #fff;
    transition: border-color 0.15s;
  }
  .field-group input:focus {
    outline: none;
    border-color: #059669;
    box-shadow: 0 0 0 3px rgba(5,150,105,0.1);
  }
  .btn-save {
    background: #059669;
    color: #fff;
    border: none;
    padding: 9px 24px;
    border-radius: 8px;
    font-size: 0.87rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-save:hover { background: #047857; }
  .hint { font-size: 0.78rem; color: #94a3b8; margin-top: 14px; }
</style>

<div class="page-header">
  <h4>My Account</h4>
  <p>Manage your profile and security settings.</p>
</div>

<div class="account-card">
  <div class="account-card-header">
    <span>Profile</span>
  </div>
  <div class="account-card-body">
    <div class="info-row">
      <div class="info-label">Email</div>
      <div class="info-value"><%= current_user.email_address %></div>
    </div>
    <div class="info-row" style="border-bottom:none; margin-bottom:0; padding-bottom:0;">
      <div class="info-label">Role</div>
      <div class="info-value">
        <span class="role-pill <%= current_user.admin? ? 'role-admin' : 'role-user' %>">
          <%= current_user.admin? ? 'Admin' : 'User' %>
        </span>
      </div>
    </div>
  </div>
</div>

<div class="account-card mt-4">
  <div class="account-card-header">
    <span>Change Password</span>
  </div>
  <div class="account-card-body">
    <%= form_with url: account_path, method: :patch do |f| %>
      <div class="field-group">
        <label>Current Password</label>
        <input type="password" name="current_password" autocomplete="current-password" required>
      </div>
      <div class="field-group">
        <label>New Password</label>
        <input type="password" name="password" autocomplete="new-password" required>
      </div>
      <div class="field-group" style="margin-bottom:20px;">
        <label>Confirm New Password</label>
        <input type="password" name="password_confirmation" autocomplete="new-password" required>
      </div>
      <button type="submit" class="btn-save">Update Password</button>
    <% end %>
    <p class="hint">You will remain signed in after changing your password.</p>
  </div>
</div>
