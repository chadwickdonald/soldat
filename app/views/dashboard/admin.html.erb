<style>
  .dash-header { margin-bottom: 36px; }
  .dash-header h4 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
  }
  .dash-header p { color: #64748b; font-size: 0.9rem; margin: 0; }

  .e-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 28px 24px;
    height: 100%;
    transition: box-shadow 0.18s, border-color 0.18s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .e-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.09);
    border-color: #a7f3d0;
    text-decoration: none;
    color: inherit;
  }
  .e-card-icon {
    width: 48px;
    height: 48px;
    background: #d1fae5;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    margin-bottom: 16px;
  }
  .e-card h5 { font-size: 1rem; font-weight: 700; color: #0f172a; margin-bottom: 6px; }
  .e-card p  { font-size: 0.85rem; color: #64748b; line-height: 1.6; margin: 0; }
  .e-arrow   { font-size: 0.8rem; color: #059669; font-weight: 600; margin-top: 14px; display: block; }
</style>

<div class="dash-header">
  <h4>Admin Dashboard</h4>
  <p>Manage users and SCADA configuration.</p>
</div>

<div class="row">
  <div class="col-md-4 mb-4">
    <a href="<%= new_user_path %>" class="e-card">
      <div class="e-card-icon">&#128100;</div>
      <h5>Create New User</h5>
      <p>Add a new user account and assign their role.</p>
      <span class="e-arrow">Create user &rarr;</span>
    </a>
  </div>

  <div class="col-md-4 mb-4">
    <a href="<%= new_scada_site_path %>" class="e-card">
      <div class="e-card-icon">&#127979;</div>
      <h5>Add SCADA Site</h5>
      <p>Register a new SCADA site and associate it with an organization.</p>
      <span class="e-arrow">Add site &rarr;</span>
    </a>
  </div>
</div>
