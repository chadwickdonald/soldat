<style>
  .dash-header {
    margin-bottom: 36px;
  }
  .dash-header h4 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.5px;
    margin-bottom: 4px;
  }
  .dash-header p {
    color: #64748b;
    font-size: 0.9rem;
    margin: 0;
  }

  .e-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 28px 24px;
    height: 100%;
    transition: box-shadow 0.18s, border-color 0.18s;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .e-card:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.09);
    border-color: #a7f3d0;
    text-decoration: none;
    color: inherit;
  }
  .e-card-icon {
    width: 48px;
    height: 48px;
    background: #d1fae5;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    margin-bottom: 16px;
  }
  .e-card h5 {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 6px;
  }
  .e-card p {
    font-size: 0.85rem;
    color: #64748b;
    line-height: 1.6;
    margin: 0;
  }
  .e-card .e-arrow {
    font-size: 0.8rem;
    color: #059669;
    font-weight: 600;
    margin-top: 14px;
    display: block;
  }
</style>

<div class="dash-header">
  <h4>Welcome back, <%= current_user.email_address.split("@").first.capitalize %></h4>
  <p>Select a module to get started.</p>
</div>

<div class="row">
  <div class="col-md-4 mb-4">
    <a href="/projects" class="e-card">
      <div class="e-card-icon">&#128451;</div>
      <h5>Projects</h5>
      <p>Browse PVsyst project files, metadata, and associated simulation data.</p>
      <span class="e-arrow">View projects &rarr;</span>
    </a>
  </div>

  <div class="col-md-4 mb-4">
    <a href="/pvsyst_simulations" class="e-card">
      <div class="e-card-icon">&#9728;&#65039;</div>
      <h5>Simulations</h5>
      <p>View hourly PVsyst simulation output and compare against actual performance.</p>
      <span class="e-arrow">View simulations &rarr;</span>
    </a>
  </div>

  <div class="col-md-4 mb-4">
    <a href="/event_data" class="e-card">
      <div class="e-card-icon">&#128200;</div>
      <h5>Event Data Explorer</h5>
      <p>Drill into SCADA measurement series by time period and station across your portfolio.</p>
      <span class="e-arrow">Open explorer &rarr;</span>
    </a>
  </div>

  <div class="col-md-4 mb-4">
    <a href="/pvsysts" class="e-card">
      <div class="e-card-icon">&#9889;</div>
      <h5>PVsyst Data</h5>
      <p>View and manage PVsyst parameter data linked to your projects.</p>
      <span class="e-arrow">View PVsyst data &rarr;</span>
    </a>
  </div>
</div>
