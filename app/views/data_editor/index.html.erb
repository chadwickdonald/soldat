<style>
  .page-header { margin-bottom: 32px; }
  .page-header h4 {
    font-size: 1.4rem;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.4px;
    margin-bottom: 4px;
  }
  .page-header p { color: #64748b; font-size: 0.9rem; margin: 0; }

  .editor-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
  }
  .editor-card-header {
    padding: 16px 24px;
    border-bottom: 2px solid #d1fae5;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .editor-card-header .record-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #059669;
  }
  .editor-card-header .record-uuid {
    font-size: 0.78rem;
    color: #94a3b8;
    font-family: monospace;
  }

  .editor-table { width: 100%; border-collapse: collapse; }
  .editor-table tr { border-bottom: 1px solid #f1f5f9; }
  .editor-table tr:last-child { border-bottom: none; }
  .editor-table td { padding: 11px 24px; vertical-align: middle; }

  .col-value {
    width: 55%;
    font-size: 0.88rem;
    color: #0f172a;
    font-weight: 500;
    word-break: break-word;
  }
  .col-value .empty-val { color: #cbd5e1; font-style: italic; font-weight: 400; }

  .col-name {
    width: 45%;
    font-size: 0.78rem;
    font-weight: 700;
    color: #64748b;
    text-align: right;
    white-space: nowrap;
  }
  .col-name .editable-badge {
    display: inline-block;
    font-size: 0.65rem;
    background: #d1fae5;
    color: #059669;
    border-radius: 4px;
    padding: 1px 6px;
    margin-left: 6px;
    font-weight: 700;
    letter-spacing: 0.04em;
    vertical-align: middle;
  }

  .edit-row td { background: #f0fdf4; }
  .edit-input {
    border: 1.5px solid #059669;
    border-radius: 6px;
    padding: 6px 10px;
    font-size: 0.88rem;
    color: #0f172a;
    width: 100%;
    background: #fff;
  }
  .edit-input:focus { outline: none; box-shadow: 0 0 0 3px rgba(5,150,105,0.15); }
  .btn-save {
    background: #059669;
    color: #fff;
    border: none;
    padding: 6px 16px;
    border-radius: 6px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    margin-top: 6px;
  }
  .btn-save:hover { background: #047857; }
  .btn-save:disabled { background: #a7f3d0; cursor: default; }

  .relevance-badge {
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 999px;
    font-weight: 600;
  }
  .relevance-high_priority                    { background: #fee2e2; color: #dc2626; }
  .relevance-detailed_analysis                { background: #dbeafe; color: #2563eb; }
  .relevance-alarms_notifications_diagnostics { background: #f1f5f9; color: #64748b; }
  .relevance-unknown                          { background: #f8fafc; color: #94a3b8; border: 1px solid #e2e8f0; }

  .pagination-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    border-top: 1px solid #e2e8f0;
    background: #f8fafc;
  }
  .pagination-bar .record-counter {
    font-size: 0.82rem;
    color: #64748b;
  }
  .pagination-bar .record-counter strong { color: #0f172a; }
  .btn-page {
    background: #fff;
    border: 1.5px solid #e2e8f0;
    border-radius: 7px;
    padding: 6px 14px;
    font-size: 0.82rem;
    font-weight: 600;
    color: #0f172a;
    text-decoration: none;
    display: inline-block;
  }
  .btn-page:hover { border-color: #059669; color: #059669; text-decoration: none; }
  .btn-page.disabled { color: #cbd5e1; border-color: #f1f5f9; pointer-events: none; }
</style>

<div class="page-header">
  <h4>Data Editor</h4>
  <p>Review and edit SCADA measurement source metadata — one record at a time.</p>
</div>

<% if @record.nil? %>
  <div class="text-center py-5 text-muted">
    <div style="font-size:2rem; margin-bottom:12px;">&#128202;</div>
    <p>No measurement sources found<% if current_user.current_scada_site %>  for the selected site<% end %>.</p>
  </div>
<% else %>
  <%
    m       = @record.scada_measurement
    fa      = m.field_alias
    label   = "#{m.apcode}-#{m.segment_name}-#{@record.calc_period}"
    relevance_labels = {
      "high_priority"                    => "High Priority",
      "detailed_analysis"                => "Detailed Analysis",
      "alarms_notifications_diagnostics" => "Alarms / Diagnostics",
      "unknown"                          => "Unknown"
    }
  %>

  <div class="editor-card">
    <div class="editor-card-header">
      <div>
        <div class="record-label">Measurement Source</div>
        <div class="record-uuid"><%= @record.uuid %></div>
      </div>
    </div>

    <%= form_with url: data_editor_record_path(@record.uuid),
                  method: :patch,
                  html: { id: "editor-form" } do |f| %>
      <%= hidden_field_tag :page, @page %>

      <table class="editor-table">
        <tbody>

          <tr>
            <td class="col-value"><%= label %></td>
            <td class="col-name">Label</td>
          </tr>

          <tr>
            <td class="col-value"><%= @record.calc_time_span_mode.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Combined Name</td>
          </tr>

          <tr>
            <td class="col-value"><%= @record.calc_period %></td>
            <td class="col-name">Calc Period</td>
          </tr>

          <tr>
            <td class="col-value"><%= @record.calc_time_span_count.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Time Span Count</td>
          </tr>

          <tr>
            <td class="col-value"><%= @record.eng_unit.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Engineering Unit</td>
          </tr>

          <tr>
            <td class="col-value"><%= fa.station_id.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Station ID</td>
          </tr>

          <tr>
            <td class="col-value"><%= fa.station_type.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Station Type</td>
          </tr>

          <tr class="edit-row">
            <td class="col-value">
              <%= f.text_field :measurement_type,
                    value: fa.measurement_type,
                    class: "edit-input",
                    id: "station-element-input",
                    autocomplete: "off" %>
              <button type="submit" class="btn-save" id="save-btn" disabled>Save changes</button>
            </td>
            <td class="col-name">
              Station Element
              <span class="editable-badge">editable</span>
            </td>
          </tr>

          <tr>
            <td class="col-value"><%= m.segment_apcode.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Segment Apcode</td>
          </tr>

          <tr>
            <td class="col-value"><%= m.segment_name.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Segment Name</td>
          </tr>

          <tr>
            <td class="col-value"><%= m.apcode.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Mloc Apcode</td>
          </tr>

          <tr>
            <td class="col-value"><%= m.name.presence || '<span class="empty-val">—</span>'.html_safe %></td>
            <td class="col-name">Measurement Name</td>
          </tr>

          <tr>
            <td class="col-value">
              <% rel = fa.relevance.to_s %>
              <span class="relevance-badge relevance-<%= rel %>">
                <%= relevance_labels[rel] || rel %>
              </span>
            </td>
            <td class="col-name">Relevance</td>
          </tr>

        </tbody>
      </table>
    <% end %>

    <div class="pagination-bar">
      <% if @page > 1 %>
        <%= link_to "← Previous", data_editor_path(page: @page - 1), class: "btn-page" %>
      <% else %>
        <span class="btn-page disabled">← Previous</span>
      <% end %>

      <span class="record-counter">
        Record <strong><%= @page %></strong> of <strong><%= @total %></strong>
      </span>

      <% if @page < @total %>
        <%= link_to "Next →", data_editor_path(page: @page + 1), class: "btn-page" %>
      <% else %>
        <span class="btn-page disabled">Next →</span>
      <% end %>
    </div>
  </div>

  <script>
    (function () {
      var input    = document.getElementById("station-element-input");
      var saveBtn  = document.getElementById("save-btn");
      var original = input ? input.value : "";

      if (!input) return;

      input.addEventListener("input", function () {
        saveBtn.disabled = (input.value.trim() === original.trim());
      });
    })();
  </script>
<% end %>
