<style>
  .page-header { margin-bottom: 28px; }
  .page-header h4 { font-size: 1.4rem; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
  .page-header p  { color: #64748b; font-size: 0.9rem; margin: 0; }
  .imports-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
  }
  .imports-table { width: 100%; border-collapse: collapse; }
  .imports-table th {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #64748b;
    padding: 12px 20px;
    border-bottom: 1px solid #e2e8f0;
    background: #f8fafc;
    text-align: left;
  }
  .imports-table td {
    padding: 12px 20px;
    font-size: 0.85rem;
    color: #0f172a;
    border-bottom: 1px solid #f1f5f9;
    vertical-align: middle;
  }
  .imports-table tr:last-child td { border-bottom: none; }
  .status-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 999px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .status-pending    { background: #fef9c3; color: #854d0e; }
  .status-processing { background: #dbeafe; color: #1d4ed8; }
  .status-completed  { background: #d1fae5; color: #065f46; }
  .status-failed     { background: #fee2e2; color: #991b1b; }
  .btn-new-import {
    background: #059669; color: #fff; border: none;
    padding: 8px 18px; border-radius: 7px; font-size: 0.82rem;
    font-weight: 600; text-decoration: none; display: inline-block;
  }
  .btn-new-import:hover { background: #047857; color: #fff; text-decoration: none; }
  .dl-link { font-size: 0.78rem; color: #059669; text-decoration: none; margin-right: 8px; }
  .dl-link:hover { text-decoration: underline; }
</style>

<div class="page-header d-flex justify-content-between align-items-start">
  <div>
    <h4>Import History</h4>
    <p>Past event data import jobs.</p>
  </div>
  <%= link_to "+ New Import", new_data_import_path, class: "btn-new-import" %>
</div>

<% if @imports.empty? %>
  <div class="text-center py-5 text-muted">
    <p>No imports yet. <%= link_to "Start one →", new_data_import_path %></p>
  </div>
<% else %>
  <div class="imports-card">
    <table class="imports-table">
      <thead>
        <tr>
          <th>#</th>
          <th>Date Range</th>
          <th>Status</th>
          <th>Specs</th>
          <th>Events</th>
          <th>Skipped</th>
          <th>Duration</th>
          <th>Downloads</th>
        </tr>
      </thead>
      <tbody>
        <% @imports.each do |imp| %>
          <tr>
            <td><%= link_to "##{imp.id}", data_import_path(imp), style: "color:#059669; font-weight:600;" %></td>
            <td style="font-family:monospace; font-size:0.78rem;"><%= imp.start_date %> → <%= imp.end_date %></td>
            <td><span class="status-badge status-<%= imp.status %>"><%= imp.status.capitalize %></span></td>
            <td><%= imp.station_count || "—" %></td>
            <td><%= imp.event_count   || "—" %></td>
            <td><%= imp.skipped_count || "—" %></td>
            <td><%= imp.duration ? "#{imp.duration.round(1)}s" : "—" %></td>
            <td>
              <% if imp.csv_1m.attached? %>
                <%= link_to "1m CSV", rails_blob_path(imp.csv_1m, disposition: :attachment), class: "dl-link" %>
              <% end %>
              <% if imp.csv_5m.attached? %>
                <%= link_to "5m CSV", rails_blob_path(imp.csv_5m, disposition: :attachment), class: "dl-link" %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
