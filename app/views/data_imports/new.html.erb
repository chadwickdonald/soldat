<style>
  .import-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 32px;
    max-width: 640px;
  }
  .import-card h5 {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 20px;
  }
  .field-group { margin-bottom: 20px; }
  .field-group label {
    display: block;
    font-size: 0.78rem;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }
  .field-group input[type="date"],
  .field-group input[type="file"] {
    width: 100%;
    border: 1.5px solid #e2e8f0;
    border-radius: 7px;
    padding: 8px 12px;
    font-size: 0.88rem;
    color: #0f172a;
    background: #fff;
  }
  .field-group input[type="date"]:focus,
  .field-group input[type="file"]:focus { outline: none; border-color: #059669; }
  .field-hint { font-size: 0.78rem; color: #94a3b8; margin-top: 4px; }
  .check-row { display: flex; align-items: center; gap: 10px; margin-bottom: 24px; }
  .check-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: #059669; }
  .check-row label { font-size: 0.88rem; color: #0f172a; font-weight: 500; margin: 0; }
  .btn-import {
    background: #059669;
    color: #fff;
    border: none;
    padding: 10px 24px;
    border-radius: 7px;
    font-size: 0.88rem;
    font-weight: 600;
    cursor: pointer;
  }
  .btn-import:hover { background: #047857; }
  .page-header { margin-bottom: 28px; }
  .page-header h4 { font-size: 1.4rem; font-weight: 800; color: #0f172a; margin-bottom: 4px; }
  .page-header p  { color: #64748b; font-size: 0.9rem; margin: 0; }
  .history-link { font-size: 0.82rem; color: #059669; text-decoration: none; }
  .history-link:hover { text-decoration: underline; }
</style>

<div class="page-header d-flex justify-content-between align-items-start">
  <div>
    <h4>Import Event Data</h4>
    <p>Upload a station JSON file and set a date range to pull events from the SCADA API.</p>
  </div>
  <%= link_to "View past imports →", data_imports_path, class: "history-link" %>
</div>

<% if @import.errors.any? %>
  <div class="alert alert-danger mb-4">
    <% @import.errors.full_messages.each do |msg| %>
      <div><%= msg %></div>
    <% end %>
  </div>
<% end %>

<div class="import-card">
  <%= form_with model: @import, html: { enctype: "multipart/form-data" } do |f| %>

    <div class="row">
      <div class="col-md-6">
        <div class="field-group">
          <%= f.label :start_date, "Start Date" %>
          <%= f.date_field :start_date, class: "" %>
        </div>
      </div>
      <div class="col-md-6">
        <div class="field-group">
          <%= f.label :end_date, "End Date" %>
          <%= f.date_field :end_date, class: "" %>
        </div>
      </div>
    </div>

    <div class="field-group">
      <%= f.label :input_json, "Station JSON File" %>
      <%= f.file_field :input_json, accept: ".json" %>
      <p class="field-hint">Upload a data_block_NNN.json file. Comments (//) are stripped automatically.</p>
    </div>

    <div class="check-row">
      <%= f.check_box :generate_csv %>
      <%= f.label :generate_csv, "Generate downloadable CSV after import" %>
    </div>

    <%= f.submit "Start Import", class: "btn-import" %>
  <% end %>
</div>
