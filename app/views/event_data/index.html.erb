<link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
<script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/luxon@3/build/global/luxon.min.js"></script>

<style>
  .page-header { margin-bottom: 32px; }
  .page-header h4 {
    font-size: 1.4rem; font-weight: 800; color: #0f172a;
    letter-spacing: -0.4px; margin-bottom: 4px;
  }
  .page-header p { color: #64748b; font-size: 0.9rem; margin: 0; }

  .period-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 20px;
  }
  .period-tab {
    padding: 7px 20px;
    border-radius: 8px;
    border: 1.5px solid #e2e8f0;
    background: #fff;
    font-size: 0.84rem;
    font-weight: 600;
    color: #64748b;
    cursor: pointer;
    transition: all 0.15s;
  }
  .period-tab:hover { border-color: #a7f3d0; color: #059669; }
  .period-tab.active {
    background: #059669;
    border-color: #059669;
    color: #fff;
  }

  .table-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 24px;
  }
  .table-card-header {
    padding: 16px 24px;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .table-card-header span {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: #059669;
  }
  .table-card-header small { font-size: 0.78rem; color: #94a3b8; }
  .table-card-hint { font-size: 0.78rem; color: #94a3b8; padding: 0 24px 12px; }

  .period-panel { display: none; }
  .period-panel.active { display: block; }

  .events-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-left: 3px solid #059669;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 24px;
    display: none;
  }
  .events-card.visible { display: block; animation: slideDown 0.18s ease-out; }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .events-card-header {
    padding: 14px 20px;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #f8fafc;
  }
  .events-card-header .events-title {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: #059669;
  }
  .events-label {
    font-size: 0.82rem; font-family: monospace; color: #475569; margin-left: 10px;
  }
  .events-close {
    background: none; border: 1.5px solid #e2e8f0; border-radius: 6px;
    padding: 4px 12px; font-size: 0.78rem; color: #64748b;
    cursor: pointer; font-weight: 600;
  }
  .events-close:hover { border-color: #94a3b8; color: #0f172a; }

  .relevance-pill {
    display: inline-block;
    font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em;
    text-transform: uppercase; padding: 2px 8px; border-radius: 999px;
  }
  .rel-high    { background: #fef2f2; color: #dc2626; }
  .rel-detail  { background: #eff6ff; color: #2563eb; }
  .rel-alarms  { background: #f1f5f9; color: #64748b; }
  .rel-unknown { background: #f8fafc; color: #94a3b8; border: 1px solid #e2e8f0; }

  .tabulator { border: none !important; border-radius: 0 !important; font-size: 0.84rem !important; }
  .tabulator .tabulator-header { background: #f8fafc !important; border-bottom: 2px solid #e2e8f0 !important; }
  .tabulator .tabulator-header .tabulator-col { background: #f8fafc !important; border-right: 1px solid #e2e8f0 !important; }
  .tabulator .tabulator-header .tabulator-col-title { font-weight: 700 !important; color: #475569 !important; font-size: 0.75rem !important; letter-spacing: 0.04em !important; text-transform: uppercase !important; }
  .tabulator-row { border-bottom: 1px solid #f1f5f9 !important; }
  .tabulator-row:hover { background: #f0fdf4 !important; cursor: pointer; }
  .tabulator-row.tabulator-selected { background: #dcfce7 !important; }
  .tabulator-row .tabulator-cell { color: #0f172a !important; border-right: 1px solid #f8fafc !important; }
  .tabulator-footer { background: #f8fafc !important; border-top: 1px solid #e2e8f0 !important; font-size: 0.8rem !important; }
  .tabulator-page.active { background: #059669 !important; border-color: #059669 !important; color: #fff !important; border-radius: 5px !important; }
  .tabulator-page { border-radius: 5px !important; }

  .site-badge {
    font-size: 0.78rem; color: #64748b;
    background: #f8fafc; border: 1px solid #e2e8f0;
    border-radius: 8px; padding: 5px 12px;
  }
  .site-badge strong { color: #0f172a; }
  .date-range-badge {
    display: inline-block;
    font-size: 0.78rem; color: #64748b;
    background: #f8fafc; border: 1px solid #e2e8f0;
    border-radius: 8px; padding: 5px 12px;
  }
</style>

<div class="page-header">
  <h4>Event Data Explorer</h4>
  <p>Drill into SCADA measurement series by time period and station across your portfolio.</p>
</div>

<div style="display:flex; align-items:center; gap:12px; margin-bottom:24px; flex-wrap:wrap;">
  <span class="date-range-badge">
    <%= Date.parse(@start_date).strftime("%b %-d, %Y") %> &rarr; <%= Date.parse(@end_date).strftime("%b %-d, %Y") %>
  </span>
  <% if @current_site %>
    <span class="site-badge">
      <strong><%= @current_site.scada_organization.name %></strong>
      &rarr;
      <strong><%= @current_site.name %></strong>
    </span>
  <% end %>
</div>

<!-- Period Tabs -->
<div class="period-tabs">
  <% @periods.each_with_index do |period, i| %>
    <button class="period-tab <%= i == 0 ? 'active' : '' %>"
            data-period="<%= period %>"
            onclick="switchPeriod('<%= period %>')">
      <% if period == '1m' %>1-Minute
      <% elsif period == '5m' %>5-Minute
      <% else %><%= period %>
      <% end %>
    </button>
  <% end %>
</div>

<!-- Period Panels -->
<% @periods.each_with_index do |period, i| %>
  <div class="period-panel <%= i == 0 ? 'active' : '' %>" id="panel-<%= period %>">
    <div class="table-card">
      <div class="table-card-header">
        <span>
          <% if period == '1m' %>1-Minute Series
          <% elsif period == '5m' %>5-Minute Series
          <% else %><%= period %> Series
          <% end %>
        </span>
        <small id="count-<%= period %>"></small>
      </div>
      <div class="table-card-hint">Click a row to view its time-series events below.</div>
      <div id="table-<%= period %>"></div>
    </div>
  </div>
<% end %>

<!-- Events Detail Panel -->
<div id="events-card" class="events-card">
  <div class="events-card-header">
    <div style="display:flex; align-items:center;">
      <span class="events-title">Time-Series Events</span>
      <span class="events-label" id="events-label"></span>
    </div>
    <div style="display:flex; align-items:center; gap:12px;">
      <small id="events-count" style="font-size:0.78rem; color:#94a3b8;"></small>
      <button class="events-close" id="events-close">&times; Close</button>
    </div>
  </div>
  <div id="events-table"></div>
</div>

<script>
(function() {
  var startDate  = "<%= @start_date %>";
  var endDate    = "<%= @end_date %>";
  var periods    = <%= raw @periods.to_json %>;
  var seriesTables = {};
  var eventsTable  = null;
  var selectedRow  = null;

  var relevanceLabels = {
    "high_priority":                    "High Priority",
    "detailed_analysis":                "Detailed Analysis",
    "alarms_notifications_diagnostics": "Alarms / Diagnostics",
    "unknown":                          "Unknown"
  };
  var relevanceClass = {
    "high_priority":                    "rel-high",
    "detailed_analysis":                "rel-detail",
    "alarms_notifications_diagnostics": "rel-alarms",
    "unknown":                          "rel-unknown"
  };

  function relevanceFormatter(cell) {
    var val   = cell.getValue();
    var label = relevanceLabels[val] || val;
    var cls   = relevanceClass[val]  || "rel-unknown";
    return '<span class="relevance-pill ' + cls + '">' + label + '</span>';
  }

  function buildSeriesTable(period) {
    var url = "/event_data/series_data?period=" + period +
              "&start_date=" + encodeURIComponent(startDate) +
              "&end_date="   + encodeURIComponent(endDate);

    var table = new Tabulator("#table-" + period, {
      ajaxURL: url,
      layout: "fitColumns",
      height: 420,
      pagination: true,
      paginationSize: 20,
      paginationSizeSelector: [10, 20, 50, 100],
      placeholder: "No series found for this period.",
      initialSort: [{ column: "station_id", dir: "asc" }],
      rowClick: function(e, row) {
        if (selectedRow) {
          try { selectedRow.deselect(); } catch(ex) {}
        }
        row.select();
        selectedRow = row;
        loadEvents(row.getData());
      },
      dataLoaded: function(data) {
        var countEl = document.getElementById("count-" + period);
        if (countEl) countEl.textContent = data.length + " series";
      },
      columns: [
        { title: "Station ID",   field: "station_id",       width: 100, sorter: "number" },
        { title: "Station Type", field: "station_type",      width: 130 },
        { title: "Element",      field: "station_element",   width: 140 },
        { title: "Segment",      field: "segment_name",      widthGrow: 2, tooltip: true },
        { title: "Measurement",  field: "measurement_name",  widthGrow: 2, tooltip: true },
        { title: "Unit",         field: "eng_unit",          width: 80  },
        { title: "Relevance",    field: "relevance",         width: 160, formatter: relevanceFormatter },
        { title: "Period",       field: "calc_period",       width: 80  }
      ]
    });

    seriesTables[period] = table;
  }

  function loadEvents(series) {
    var card    = document.getElementById("events-card");
    var labelEl = document.getElementById("events-label");
    var countEl = document.getElementById("events-count");
    card.classList.add("visible");
    labelEl.textContent = series.label || "";
    countEl.textContent = "Loading…";
    card.scrollIntoView({ behavior: "smooth", block: "start" });

    var url = "/event_data/events_data?uuid=" + encodeURIComponent(series.uuid) +
              "&start_date=" + encodeURIComponent(startDate) +
              "&end_date="   + encodeURIComponent(endDate);

    if (eventsTable) {
      eventsTable.setData(url);
    } else {
      eventsTable = new Tabulator("#events-table", {
        ajaxURL: url,
        layout: "fitColumns",
        height: 340,
        pagination: true,
        paginationSize: 25,
        paginationSizeSelector: [25, 50, 100, 288],
        placeholder: "No events in this date range.",
        dataLoaded: function(data) {
          countEl.textContent = data.length + " events";
        },
        columns: [
          {
            title: "Timestamp",
            field: "date",
            sorter: "datetime",
            sorterParams: { format: "iso" },
            formatter: "datetime",
            formatterParams: {
              inputFormat:  "iso",
              outputFormat: "yyyy-MM-dd HH:mm:ss",
              invalidPlaceholder: "(invalid)",
              timezone: "UTC"
            },
            widthGrow: 2
          },
          {
            title: "Value (" + (series.eng_unit || "—") + ")",
            field: "val",
            sorter: "number",
            formatter: function(cell) {
              var v = cell.getValue();
              if (v === null || v === undefined) return "—";
              return parseFloat(v).toLocaleString(undefined, { maximumFractionDigits: 4 });
            },
            widthGrow: 1,
            hozAlign: "right"
          }
        ]
      });
    }
  }

  document.getElementById("events-close").addEventListener("click", function() {
    document.getElementById("events-card").classList.remove("visible");
    if (selectedRow) {
      try { selectedRow.deselect(); } catch(ex) {}
      selectedRow = null;
    }
  });

  periods.forEach(function(period) { buildSeriesTable(period); });
})();

function switchPeriod(period) {
  document.querySelectorAll(".period-tab").forEach(function(btn) {
    btn.classList.toggle("active", btn.dataset.period === period);
  });
  document.querySelectorAll(".period-panel").forEach(function(panel) {
    panel.classList.toggle("active", panel.id === "panel-" + period);
  });
}
</script>
