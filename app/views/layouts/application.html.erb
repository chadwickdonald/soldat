<!DOCTYPE html>
<html>
  <head>
    <title>Enthasys</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" type="image/svg+xml" href="<%= asset_path('enthasys_favicon.svg') %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tabulator/5.5.1/css/tabulator_bootstrap5.min.css" integrity="sha512-TXz7LLClXvOmlbp5sAQD5Pdtd9pvHEk+XPxgCpT8qddJeHIHe5nAXIj/1QhBrt6e3KJtWEnl6wEai/v+IV1J2w==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <a class="navbar-brand p-0" href="/">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="55 22 385 78" height="36" fill="none" aria-label="Enthasys">
            <rect x="60" y="32" width="40" height="6" rx="3" fill="#9FE1CB"/>
            <rect x="60" y="47" width="28" height="6" rx="3" fill="#9FE1CB"/>
            <rect x="60" y="62" width="40" height="6" rx="3" fill="#9FE1CB"/>
            <circle cx="112" cy="35" r="9" fill="#1D9E75"/>
            <circle cx="112" cy="35" r="5" fill="#0d2420"/>
            <line x1="100" y1="35" x2="103" y2="35" stroke="#1D9E75" stroke-width="2" stroke-linecap="round"/>
            <text x="142" y="68" font-family="sans-serif" font-size="32" font-weight="500" letter-spacing="4" fill="#d1fae5">ENTHASYS</text>
          </svg>
        </a>
        <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#mainNav"
                aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav mr-auto mt-2 mt-lg-0">
            <% if current_user&.admin? %>
              <li class="nav-item">
                <a class="nav-link" href="/imports">Import</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="/users">Users</a>
              </li>
            <% end %>
          </ul>
          <% unless current_user %>
            <ul class="navbar-nav mx-auto mt-2 mt-lg-0">
              <li class="nav-item">
                <%= link_to "About", about_path, class: "nav-link" %>
              </li>
              <li class="nav-item">
                <%= link_to "Contact", contact_path, class: "nav-link" %>
              </li>
            </ul>
          <% end %>
          <% if current_user %>
            <div class="d-flex align-items-center">
              <span class="text-muted small mr-3">
                <%= current_user.email_address %>
                <span class="badge badge-<%= current_user.admin? ? 'warning' : 'secondary' %> ml-1">
                  <%= current_user.admin? ? 'Admin' : 'User' %>
                </span>
              </span>
              <%= button_to "Sign out", session_path, method: :delete,
                    class: "btn btn-outline-light btn-sm",
                    form: { style: "display:inline" } %>
            </div>
          <% else %>
            <%= link_to "Login", new_session_path, class: "btn btn-outline-light btn-sm" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if flash[:notice] %>
      <div class="alert alert-success alert-dismissible fade show mb-0 rounded-0" role="alert">
        <div class="container"><%= flash[:notice] %></div>
        <button type="button" class="close pr-4" data-dismiss="alert">&times;</button>
      </div>
    <% end %>
    <% if flash[:alert] %>
      <div class="alert alert-danger alert-dismissible fade show mb-0 rounded-0" role="alert">
        <div class="container"><%= flash[:alert] %></div>
        <button type="button" class="close pr-4" data-dismiss="alert">&times;</button>
      </div>
    <% end %>

    <div class="container py-5">
      <%= yield %>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.4.slim.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js" crossorigin="anonymous"></script>
  </body>
</html>
