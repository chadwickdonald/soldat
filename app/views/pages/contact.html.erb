<style>
  .contact-wrap {
    max-width: 600px;
    margin: 0 auto;
  }
  .contact-wrap h1 {
    font-size: 2rem;
    font-weight: 800;
    color: #0f172a;
    letter-spacing: -0.75px;
    line-height: 1.2;
    margin-bottom: 14px;
  }
  .contact-wrap .lead {
    color: #64748b;
    font-size: 1rem;
    line-height: 1.65;
    margin-bottom: 40px;
  }
  .contact-wrap .form-control {
    border: 1.5px solid #e2e8f0;
    border-radius: 8px;
    padding: 11px 14px;
    font-size: 0.9rem;
    color: #0f172a;
  }
  .contact-wrap .form-control:focus {
    border-color: #059669;
    box-shadow: 0 0 0 3px rgba(5,150,105,0.1);
  }
  .contact-wrap label {
    font-size: 0.8rem;
    font-weight: 600;
    color: #475569;
    margin-bottom: 5px;
  }
  .btn-send {
    background: #059669;
    color: #fff;
    border: none;
    padding: 12px 28px;
    font-weight: 600;
    border-radius: 8px;
    font-size: 0.95rem;
  }
  .btn-send:hover {
    background: #047857;
    color: #fff;
  }
</style>

<div class="contact-wrap">
  <h1>Have a question about Enthasys, or want to learn more about our data?</h1>
  <p class="lead">Send us a note and we'll get back to you within 24 hours.</p>

  <%= form_with url: send_contact_path, method: :post do |f| %>
    <div class="form-group">
      <%= f.label :name, "Name" %>
      <%= f.text_field :name, class: "form-control", placeholder: "Your name", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :email, "Email" %>
      <%= f.email_field :email, class: "form-control", placeholder: "you@example.com", required: true %>
    </div>

    <div class="form-group">
      <%= f.label :message, "Message" %>
      <%= f.text_area :message, class: "form-control", rows: 6,
            placeholder: "What would you like to know?", required: true %>
    </div>

    <%= f.submit "Send message", class: "btn btn-send mt-2" %>
  <% end %>
</div>
