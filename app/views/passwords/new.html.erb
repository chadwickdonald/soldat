<style>
  .login-card {
    max-width: 420px;
    margin: 60px auto 0;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 40px;
    background: #fff;
  }
  .login-brand { font-size: 1.5rem; font-weight: 800; color: #059669; letter-spacing: -0.5px; margin-bottom: 6px; }
  .login-tagline { color: #64748b; font-size: 0.875rem; margin-bottom: 28px; }
  .login-card .form-control {
    border-radius: 8px;
    border: 1.5px solid #e2e8f0;
    padding: 10px 14px;
    font-size: 0.9rem;
  }
  .login-card .form-control:focus {
    border-color: #059669;
    box-shadow: 0 0 0 3px rgba(5,150,105,0.1);
  }
  .btn-login {
    background: #059669;
    color: #fff;
    border: none;
    width: 100%;
    padding: 11px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.95rem;
    margin-top: 4px;
  }
  .btn-login:hover { background: #047857; color: #fff; }
</style>

<div class="login-card shadow-sm">
  <div class="login-brand">Enthasys</div>
  <div class="login-tagline">Reset your password</div>

  <% if flash[:alert] %>
    <div class="alert alert-danger py-2 small"><%= flash[:alert] %></div>
  <% end %>
  <% if flash[:notice] %>
    <div class="alert alert-success py-2 small"><%= flash[:notice] %></div>
  <% end %>

  <p class="small text-muted mb-4">Enter your email address and we'll send you a link to reset your password.</p>

  <%= form_with url: passwords_path do |f| %>
    <div class="form-group">
      <%= f.label :email_address, "Email address", class: "small font-weight-600 text-muted" %>
      <%= f.email_field :email_address, class: "form-control", required: true,
            autofocus: true, autocomplete: "username",
            placeholder: "you@example.com", value: params[:email_address] %>
    </div>
    <%= f.submit "Send reset instructions", class: "btn btn-login" %>
  <% end %>

  <div class="text-center mt-3">
    <%= link_to "Back to sign in", new_session_path, class: "small text-muted" %>
  </div>
</div>
