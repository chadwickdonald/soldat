<link href="https://unpkg.com/tabulator-tables@5.5.0/dist/css/tabulator_bootstrap5.min.css" rel="stylesheet">
<script src="https://unpkg.com/tabulator-tables@5.5.0/dist/js/tabulator.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/luxon@3/build/global/luxon.min.js"></script>

<style>
  .page-header { margin-bottom: 32px; }
  .page-header h4 {
    font-size: 1.4rem; font-weight: 800; color: #0f172a;
    letter-spacing: -0.4px; margin-bottom: 4px;
  }
  .page-header p { color: #64748b; font-size: 0.9rem; margin: 0; }

  .table-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    overflow: hidden;
  }
  .table-card-header {
    padding: 16px 24px;
    border-bottom: 1px solid #e2e8f0;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .table-card-header span {
    font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: #059669;
  }
  .table-card-header small { font-size: 0.78rem; color: #94a3b8; }

  .tabulator {
    border: none !important;
    border-radius: 0 !important;
    font-size: 0.84rem !important;
  }
  .tabulator .tabulator-header { background: #f8fafc !important; border-bottom: 2px solid #e2e8f0 !important; }
  .tabulator .tabulator-header .tabulator-col { background: #f8fafc !important; border-right: 1px solid #e2e8f0 !important; }
  .tabulator .tabulator-header .tabulator-col-title { font-weight: 700 !important; color: #475569 !important; font-size: 0.75rem !important; letter-spacing: 0.04em !important; text-transform: uppercase !important; }
  .tabulator-row { border-bottom: 1px solid #f1f5f9 !important; }
  .tabulator-row:hover { background: #f0fdf4 !important; }
  .tabulator-row .tabulator-cell { color: #0f172a !important; border-right: 1px solid #f8fafc !important; }
  .tabulator-footer { background: #f8fafc !important; border-top: 1px solid #e2e8f0 !important; font-size: 0.8rem !important; }
  .tabulator-page.active { background: #059669 !important; border-color: #059669 !important; color: #fff !important; border-radius: 5px !important; }
  .tabulator-page { border-radius: 5px !important; }
</style>

<div class="page-header">
  <h4>Projects</h4>
  <p>PVsyst project files and associated simulation metadata.</p>
</div>

<div class="table-card">
  <div class="table-card-header">
    <span>All Projects</span>
    <small id="project-count"></small>
  </div>
  <div id="projects-table"></div>
</div>

<script>
  var projectsTable = new Tabulator("#projects-table", {
    height: 520,
    layout: "fitColumns",
    ajaxURL: "/projects/table_data",
    pagination: true,
    paginationSize: 20,
    paginationSizeSelector: [10, 20, 40, 80],
    placeholder: "No projects found.",
    dataLoaded: function (data) {
      var el = document.getElementById("project-count");
      if (el) el.textContent = data.length + " record" + (data.length === 1 ? "" : "s");
    },
    columns: [
      { title: "Name",              field: "project",                    minWidth: 160, tooltip: true },
      { title: "Description",       field: "project_description",        minWidth: 160, tooltip: true },
      { title: "PVsyst Version",    field: "pvsyst_version",             width: 130 },
      { title: "Simulation Date",   field: "simulation_date",            width: 160,
        formatter: "datetime",
        formatterParams: { inputFormat: "iso", outputFormat: "dd MMM yyyy", invalidPlaceholder: "—" } },
      { title: "Geo Site",          field: "geographical_site",          minWidth: 160, tooltip: true },
      { title: "Meteo Data",        field: "meteo_data",                 minWidth: 160, tooltip: true },
      { title: "Satellite Data",    field: "satelite_data",              minWidth: 140, tooltip: true },
      { title: "Simulation Variant",field: "simulation_variant",         minWidth: 180, tooltip: true },
      { title: "Hours From",        field: "simulation_hourly_values_from", width: 120 },
      { title: "Hours To",          field: "simulation_hourly_values_to",   width: 120 },
    ],
  });
</script>
