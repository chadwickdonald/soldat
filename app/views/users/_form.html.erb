<%= form_with model: user, class: "needs-validation" do |f| %>
  <% if user.errors.any? %>
    <div class="alert alert-danger">
      <% user.errors.full_messages.each do |msg| %>
        <div><%= msg %></div>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :email_address, "Email address" %>
    <%= f.email_field :email_address, class: "form-control", required: true, autocomplete: "off" %>
  </div>

  <div class="form-group">
    <%= f.label :role %>
    <%= f.select :role, User.roles.keys.map { |r| [r.humanize, r] }, {}, class: "form-control" %>
  </div>

  <div class="form-group">
    <%= f.label :password, user.persisted? ? "New password (leave blank to keep current)" : "Password" %>
    <%= f.password_field :password, class: "form-control", autocomplete: "new-password",
          required: !user.persisted?, minlength: 12 %>
  </div>

  <div class="form-group">
    <%= f.label :password_confirmation, "Confirm password" %>
    <%= f.password_field :password_confirmation, class: "form-control", autocomplete: "new-password" %>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-4">
    <%= link_to "Cancel", users_path, class: "btn btn-outline-secondary" %>
    <%= f.submit user.persisted? ? "Save changes" : "Create user", class: "btn btn-success" %>
  </div>
<% end %>
