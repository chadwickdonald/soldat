<div class="d-flex justify-content-between align-items-center mb-4">
  <h4 class="mb-0 font-weight-bold">Users</h4>
  <%= link_to "Add User", new_user_path, class: "btn btn-success btn-sm" %>
</div>

<% if flash[:notice] %>
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <%= flash[:notice] %>
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
  </div>
<% end %>
<% if flash[:alert] %>
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <%= flash[:alert] %>
    <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
  </div>
<% end %>

<div class="card border-0 shadow-sm">
  <table class="table table-hover mb-0">
    <thead class="thead-light">
      <tr>
        <th>Email</th>
        <th>Role</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users.each do |user| %>
        <tr>
          <td class="align-middle"><%= user.email_address %></td>
          <td class="align-middle">
            <% if user.admin? %>
              <span class="badge badge-dark">Admin</span>
            <% else %>
              <span class="badge badge-secondary">User</span>
            <% end %>
          </td>
          <td class="align-middle text-muted small"><%= user.created_at.strftime("%b %-d, %Y") %></td>
          <td class="align-middle text-right">
            <%= link_to "Edit", edit_user_path(user), class: "btn btn-outline-secondary btn-sm mr-1" %>
            <% unless user == current_user %>
              <%= button_to "Remove", user_path(user), method: :delete,
                    class: "btn btn-outline-danger btn-sm",
                    form: { data: { confirm: "Remove #{user.email_address}?" } } %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
